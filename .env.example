# Solana Network (devnet, testnet, mainnet-beta)
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# zkRUNE Token Mint Address
# Devnet: A619D39h4CxHT7rSSurWAb2Un36c6W8BLyJWBYGxzstP
# Mainnet: 51mxznNWNBHh6iZWwNHBokoaxHYS2Amds1hhLGXkpump
NEXT_PUBLIC_ZKRUNE_MINT=A619D39h4CxHT7rSSurWAb2Un36c6W8BLyJWBYGxzstP

# Staking Program ID
NEXT_PUBLIC_STAKING_PROGRAM_ID=44ToPJzWsnqJRhvFS5wXLsgWGWpbe3YwhU9t8LkQBRiX

# Groth16 Verifier Program
NEXT_PUBLIC_GROTH16_VERIFIER_PROGRAM=9apA5U8YywgTHXQqpbvUMHJej7yorHcN56cewKfkX7ad

# Helius API key — required for snapshot-holders.ts (free at helius.dev)
# Without this, snapshot falls back to getProgramAccounts which public RPCs block.
HELIUS_API_KEY=your_helius_api_key_here

# Whale Chat — Telegram invite link (keep out of source code)
NEXT_PUBLIC_WHALE_CHAT_LINK=https://t.me/+your_invite_hash_here

# Supabase (required for Governance + Marketplace)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Platform treasury wallet (receives operational reserve from marketplace fees)
NEXT_PUBLIC_TREASURY_ADDRESS=your_treasury_wallet_address

# Staking reward vault — token account that funds staker rewards.
# Marketplace platform fees are routed here (controlled by REWARD_POOL_SHARE in config).
NEXT_PUBLIC_REWARD_VAULT_ADDRESS=your_reward_vault_token_account

# Faucet Private Key (base58 or JSON array, only for devnet admin)
# FAUCET_PRIVATE_KEY=[...]
