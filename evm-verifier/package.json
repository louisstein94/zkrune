{
  "name": "zkrune-evm-verifier",
  "version": "1.0.0",
  "description": "zkRune Groth16 proof verifier for EVM chains (Ethereum, Base, Arbitrum)",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network sepolia",
    "deploy:base-sepolia": "hardhat run scripts/deploy.ts --network baseSepolia",
    "register:base-sepolia": "hardhat run scripts/registerCircuits.ts --network baseSepolia",
    "deploy:local": "hardhat run scripts/deploy.ts",
    "deploy:local:verify": "hardhat run scripts/deployAndVerifyLocal.ts"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "hardhat": "^2.22.0",
    "typescript": "^5.0.0",
    "ts-node": "^10.9.0",
    "@types/node": "^20.0.0",
    "dotenv": "^16.4.5",
    "snarkjs": "^0.7.4"
  }
}
