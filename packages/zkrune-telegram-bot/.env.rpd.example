# Second deployment of the same bot package, for Red Panda (RPD).
# Run as a separate Railway service / Docker container with this env file.
# Never commit the real .env.rpd — use this as a template.

BOT_TOKEN=
# Static invite link sent to verified whales. The bot does not need to be in
# this group — it just forwards the link, then auto-deletes its own message
# after INVITE_TTL_SECONDS.
WHALE_INVITE_URL=https://t.me/+VjlhLQ8pWWQxODg0

HELIUS_API_KEY=

TOKEN_MINT=BeSKJL54vJ8VeqhPBXeHMgFMJnbHxfDN3pARDmvApump
TOKEN_DECIMALS=6
TOKEN_SYMBOL=RPD
TOKEN_NAME=Red Panda
EXPECTED_MIN_BALANCE=10000000

# Telegram Mini App URL — point this at the rpd-whale-web Vercel/Railway deploy.
# After deploying packages/rpd-whale-web/, register the domain with @BotFather:
#   /setdomain → choose this bot → enter the deploy URL
MINI_APP_URL=https://rpd-whale.vercel.app

# Optional fallback if user is outside Telegram (manual JSON upload path)
PROOF_URL=https://rpd-whale.vercel.app

INVITE_TTL_SECONDS=30

VKEY_PATH=./keys/whale-holder_vkey.json
# Use distinct store dirs so the RPD deployment does not share verified-users
# or nullifier files with the zkRUNE deployment if both run on one host.
DATA_DIR=../data-rpd
STORE_DIR=../store-rpd

PORT=3000
