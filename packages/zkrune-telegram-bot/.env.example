# Telegram Bot Token (from @BotFather)
BOT_TOKEN=

# Chat ID of the private whale group (-100xxxxxxxxxx)
WHALE_GROUP_ID=

# URL where users generate their ZK proof
PROOF_URL=https://zkrune.com/whale-chat

# Path to the verification key JSON (bundled in data/ for Railway)
VKEY_PATH=./keys/whale-holder_vkey.json

# Helius API key for fetching token holders (free at helius.dev)
HELIUS_API_KEY=

# HTTP port for snapshot server (Railway sets PORT automatically)
PORT=3000
