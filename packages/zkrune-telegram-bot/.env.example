# ── Required ──────────────────────────────────────────────────────────────────

# Telegram Bot Token (from @BotFather) — never commit a real value
BOT_TOKEN=

# Static invite link to the private whale group (https://t.me/+XXXXXXXX).
# The bot does NOT need to be in this group — it just sends the link as-is
# after verification, then auto-deletes its own message after INVITE_TTL_SECONDS.
WHALE_INVITE_URL=

# Helius API key (https://helius.dev) — used to fetch holders for the snapshot
HELIUS_API_KEY=

# ── Token (defaults to zkRUNE mainnet) ────────────────────────────────────────

TOKEN_MINT=51mxznNWNBHh6iZWwNHBokoaxHYS2Amds1hhLGXkpump
TOKEN_DECIMALS=6
TOKEN_SYMBOL=zkRUNE
TOKEN_NAME=zkRune

# Optional: reject proofs whose minimumBalance public signal is below this
# (in whole-token units). Prevents proofs generated against a lower threshold.
EXPECTED_MIN_BALANCE=10000000

# ── UX ────────────────────────────────────────────────────────────────────────

# Telegram Mini App URL — opened from the keyboard button in /start. The page
# generates the proof in-browser and sends it back via Telegram.WebApp.sendData,
# which the bot receives as a message:web_app_data event (no HTTP server hop).
# Must be HTTPS and registered with @BotFather (/setdomain or /newapp).
MINI_APP_URL=

# Legacy fallback URL shown when MINI_APP_URL is not set. Users open the page
# in a regular browser and upload the exported proof JSON to this chat.
PROOF_URL=https://zkrune.com/whale-chat

# How long the invite link message stays visible before auto-deletion
INVITE_TTL_SECONDS=30

# ── Storage / runtime ─────────────────────────────────────────────────────────

# Path to the verification key JSON
VKEY_PATH=./keys/whale-holder_vkey.json

# Snapshot data dir (per-deployment to avoid collisions)
DATA_DIR=../data

# Nullifier + verified-user store dir (per-deployment)
STORE_DIR=..

# HTTP port for the snapshot server (Railway sets PORT automatically)
PORT=3000
