{
  "name": "zkrune-widget",
  "version": "1.0.0",
  "description": "Embeddable ZK verification widget — drop a script tag to add privacy proofs to any site",
  "main": "dist/zkrune-widget.js",
  "module": "dist/zkrune-widget.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/zkrune-widget.mjs",
      "require": "./dist/zkrune-widget.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "zkrune",
    "zero-knowledge",
    "widget",
    "embed",
    "privacy",
    "verification",
    "groth16"
  ],
  "author": "zkRune Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/louisstein94/zkrune.git",
    "directory": "packages/zkrune-widget"
  },
  "homepage": "https://zkrune.com",
  "devDependencies": {
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  }
}
